rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - createdAt: string (optional)
    //
    // Collection: cvs
    // Document ID: cvId (auto-generated)
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - createdAt: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "peter25ngouala@gmail.com"
        );
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string;
    }

    function isValidCV(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.title is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
    }

    match /cvs/{cvId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCV(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidCV(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /cover_letters/{letterId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /payment_requests/{requestId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /promo_codes/{promoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAdmin();
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isDocOwner() || isAdmin();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
